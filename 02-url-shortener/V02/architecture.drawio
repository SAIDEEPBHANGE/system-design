        <!-- ===================== FLOW EDGES ===================== -->
        <mxCell id="e1" value="1. Fetch static assets (HTTPS)" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;strokeColor=#333333;fontSize=10;" edge="1" parent="1" source="client_app" target="cdn">
