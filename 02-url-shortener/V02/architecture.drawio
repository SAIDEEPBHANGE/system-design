<mxfile host="app.diagrams.net">
  <diagram name="URL Shortener - Standards Compliant" id="url-shortener-v2">
    <mxGraphModel dx="2289" dy="1260" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="1750" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===================== TITLE ===================== -->
        <mxCell id="title" value="URL Shortener — System Architecture" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="820" height="30" as="geometry" />
        </mxCell>

        <!-- ===================== CLIENT TIER (Blue) ===================== -->
        <mxCell id="grp_client" value="Client Tier" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;fontStyle=1;fontColor=#1a5276;fillColor=#eaf2fb;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="820" height="110" as="geometry" />
        </mxCell>
        <mxCell id="client_app" value="Browser / Mobile SPA Application" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="90" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- CDN - external, light blue, dashed border (third-party) -->
        <mxCell id="cdn" value="CDN&#10;(CloudFront / Cloudflare)&#10;Static assets + thumbnails" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#d0e3f7;strokeColor=#6c8ebf;dashed=1;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="960" y="60" width="260" height="130" as="geometry" />
        </mxCell>

