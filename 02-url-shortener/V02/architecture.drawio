        <mxCell id="leg_cdn" value="CDN (external, dashed)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d0e3f7;strokeColor=#6c8ebf;dashed=1;fontSize=11;" vertex="1" parent="1">
