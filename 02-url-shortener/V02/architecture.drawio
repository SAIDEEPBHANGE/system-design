        <mxCell id="leg_note" value="Rounded rect = Microservice&#10;Cylinder = Database/Cache&#10;Diamond = LB / Decision&#10;Cloud, dashed = External system" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="915" y="545" width="310" height="80" as="geometry" />
