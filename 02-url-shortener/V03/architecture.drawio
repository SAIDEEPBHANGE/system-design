"1060" width="190" height="50" as="geometry"/></mxCell><mxCell id="n131" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontColor=#4d4d4d;" value="Ops Alert +&#xa;Manual/Automated Replay"><mxGeometry x="2010" y="1125" width="190" height="45" as="geometry"/></mxCell><mxCell id="n133" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Cache-Invalidation Consumer Group&#xa;(N=2, idempotent, at-least-once)"><mxGeometry x="1460" y="1160" width="300" height="55" as="geometry"/></mxCell><mxCell id="n136" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Kafka MirrorMaker 2 → replicates topics to Region A (DR)"><mxGeometry x="1240" y="1240" width="960" height="40" as="geometry"/></mxCell><mxCell id="n139" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontStyle=1;fillColor=none;strokeColor=#999999;dashed=1;" value="Data Layer — Sharded NoSQL Cluster (multi-DC, active-active)"><mxGeometry x="40" y="1420" width="2680" height="470" as="geometry"/></mxCell><mxCell id="n140" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Links Collection (sharded by hash(short_code))"><mxGeometry x="60" y="1445" width="700" height="20" as="geometry"/></mxCell><mxCell id="n141" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 1&#xa;Primary (Region A)"><mxGeometry x="60" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n142" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 1&#xa;Replica (Region A, sync)"><mxGeometry x="280" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n143" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 1&#xa;Write Node (Region B, multi-DC)"><mxGeometry x="500" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n146" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 2&#xa;Primary (Region A)"><mxGeometry x="820" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n147" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 2&#xa;Replica (Region A, sync)"><mxGeometry x="1040" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n148" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 2&#xa;Write Node (Region B, multi-DC)"><mxGeometry x="1260" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n151" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 3&#xa;Primary (Region A)"><mxGeometry x="1580" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n152" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 3&#xa;Replica (Region A, sync)"><mxGeometry x="1800" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n153" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Shard 3&#xa;Write Node (Region B, multi-DC)"><mxGeometry x="2020" y="1475" width="190" height="90" as="geometry"/></mxCell><mxCell id="n159" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fillColor=#ffffe0;strokeColor=#d6b656;fontSize=10;" value="Multi-DC replication (e.g. Cassandra NetworkTopologyStrategy / DynamoDB Global Tables): both regions read &amp; write locally; conflicts resolved via LWW / vector clocks. Consistent-hash sharding avoids a single write bottleneck."><mxGeometry x="60" y="1590" width="900" height="55" as="geometry"/></mxCell><mxCell id="n160" parent="1" vertex="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" value="Users / Auth Collection&#xa;(Primary + 2 Replicas, same HA pattern as Links)"><mxGeometry x="60" y="1670" width="520" height="110" as="geometry"/></mxCell><mxCell id="n163" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fillColor=#ffffe0;strokeColor=#d6b656;fontSize=10;" value="Login table fields: user_id (PK), email (unique idx), password_hash (bcrypt/argon2), created_at, last_login_at, status, failed_login_count. Sessions/JWT refresh tokens cached in Redis (per region) with TTL."><mxGeometry x="620" y="1670" width="700" height="120" as="geometry"/></mxCell><mxCell id="n164" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fillColor=#ffffe0;strokeColor=#d6b656;fontSize=10;" value="TTL &amp; Soft-Delete Policy:&#xa;1) Soft delete: Write Service sets soft_deleted=true, deleted_at=now() (keeps audit trail, reversible).&#xa;2) Native NoSQL TTL index on expires_at auto-purges hard-expired docs.&#xa;3) Reaper Worker (every 5 min) hard-deletes soft_deleted docs older than 30-day grace period and emits &#x27;link.purged&#x27; event."><mxGeometry x="1400" y="1670" width="660" height="150" as="geometry"/></mxCell><mxCell id="n165" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" value="TTL Reaper / Expiry&#xa;Scanner (scheduled worker)"><mxGeometry x="2100" y="1720" width="220" height="55" as="geometry"/></mxCell><mxCell id="n169" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontStyle=1;fillColor=none;strokeColor=#999999;dashed=1;" value="Observability &amp; Monitoring Stack (cross-cutting, both regions)"><mxGeometry x="40" y="1920" width="2680" height="300" as="geometry"/></mxCell><mxCell id="n170" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="Prometheus&#xa;(metrics, multi-region federation)"><mxGeometry x="100" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n171" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="OpenTelemetry Collector&#xa;+ Jaeger (distributed tracing)"><mxGeometry x="360" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n172" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="Loki / ELK&#xa;(centralized structured logs)"><mxGeometry x="620" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n173" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="Grafana&#xa;(dashboards)"><mxGeometry x="880" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n174" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="Alertmanager"><mxGeometry x="1140" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n175" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#333333;fontColor=#ffffff;fontStyle=1;" value="Synthetic Monitoring / Health Aggregator&#xa;(feeds Global Traffic Manager)"><mxGeometry x="1400" y="1960" width="320" height="55" as="geometry"/></mxCell><mxCell id="n176" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;fontColor=#4d4d4d;" value="PagerDuty / Slack&#xa;(on-call paging)"><mxGeometry x="1760" y="1960" width="220" height="55" as="geometry"/></mxCell><mxCell id="n185" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fillColor=#ffffe0;strokeColor=#d6b656;fontSize=10;" value="Every service in both regions exposes /health and /metrics (scraped by Prometheus), ships structured logs to Loki/ELK via sidecar shippers, and emits traces to the OTel Collector. Health-check results also flow to the regional Service Registry (fast local failover) and to the Synthetic Monitoring Aggregator (slow global failover via the Global Traffic Manager). Remaining scrape/health links omitted for readability — the pattern above applies uniformly to every node in this diagram."><mxGeometry x="100" y="2040" width="1880" height="120" as="geometry"/></mxCell><mxCell id="n186" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontStyle=1;fillColor=none;strokeColor=#999999;dashed=1;" value="Legend"><mxGeometry x="2260" y="260" width="460" height="1080" as="geometry"/></mxCell><mxCell id="n187" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value=""><mxGeometry x="2275" y="300" width="150" height="26" as="geometry"/></mxCell><mxCell id="n188" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Client / Frontend"><mxGeometry x="2435" y="300" width="270" height="26" as="geometry"/></mxCell><mxCell id="n189" parent="1" vertex="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#d0e3f7;strokeColor=#6c8ebf;dashed=1;" value=""><mxGeometry x="2275" y="334" width="150" height="26" as="geometry"/></mxCell><mxCell id="n190" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="CDN / External (dashed)"><mxGeometry x="2435" y="334" width="270" height="26" as="geometry"/></mxCell><mxCell id="n191" parent="1" vertex="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" value=""><mxGeometry x="2275" y="368" width="150" height="26" as="geometry"/></mxCell><mxCell id="n192" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Load Balancer / Decision"><mxGeometry x="2435" y="368" width="270" height="26" as="geometry"/></mxCell><mxCell id="n193" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" value=""><mxGeometry x="2275" y="402" width="150" height="26" as="geometry"/></mxCell><mxCell id="n194" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Edge / Gateway component"><mxGeometry x="2435" y="402" width="270" height="26" as="geometry"/></mxCell><mxCell id="n195" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value=""><mxGeometry x="2275" y="436" width="150" height="26" as="geometry"/></mxCell><mxCell id="n196" parent="1" vertex="1" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;" value="Backend Service"><mxGeometry x="2435" y="436" width="270" height="26" as="geometry"/></mxCell><mxCell id="n197" parent="1" vertex="1" style="rounded=1;whiteSpace