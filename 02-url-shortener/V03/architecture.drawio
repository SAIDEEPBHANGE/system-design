        <mxCell id="n1" parent="1" vertex="1" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" value="URL Shortener — Multi-Region, HA System Architecture (No Single Point of Failure)"><mxGeometry x="40" y="10" width="2680" height="34" as="geometry"/></mxCell><mxCell id="n2" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontStyle=1;fillColor=none;strokeColor=#999999;dashed=1;" value="Global Layer"><mxGeometry x="40" y="50" width="2680" height="190" as="geometry"/></mxCell><mxCell id="n3" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value="Browser / Mobile SPA&#xa;Client"><mxGeometry x="560" y="90" width="260" height="55" as="geometry"/></mxCell><mxCell id="n4" parent="1" vertex="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#d0e3f7;strokeColor=#6c8ebf;dashed=1;" value="GeoDNS / Route53&#xa;(Latency + Health-based routing)"><mxGeometry x="980" y="90" width="260" height="80" as="geometry"/></mxCell><mxCell id="n5" parent="1" vertex="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#d0e3f7;strokeColor=#6c8ebf;dashed=1;" value="Global CDN&#xa;(CloudFront/Cloudflare)&#xa;Static assets + edge cache"><mxGeometry x="1500" y="80" width="260" height="100" as="geometry"/></mxCell><mxCell id="n6" parent="1" vertex="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" value="Global Traffic Manager&#xa;(Active-Active, cross-region failover)"><mxGeometry x="980" y="180" width="260" height="55" as="geometry"/></mxCell><mxCell id="n10" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontStyle=1;fillColor=none;strokeColor=#999999;dashed=1;" value="Region A — us-east-1 (Active)"><mxGeometry x="40" y="260" width="1040" height="1080" as="geometry"/></mxCell><mxCell id="n11" pare